@model CustomerCRUD.Models.Customer

@{
    ViewData["Title"] = "Delete Customer";
}

<div class="container mt-4" style="max-width: 500px;">
    <h2 class="mb-4 text-danger">Delete Customer</h2>

    <div class="card border-danger">
        <div class="card-body">
            <p class="card-text">Are you sure you want to delete this customer? This action cannot be undone.</p>
            <hr />
            <dl class="row">
                <dt class="col-sm-4">ID</dt>
                <dd class="col-sm-8">@Model.Id</dd>
                <dt class="col-sm-4">First Name</dt>
                <dd class="col-sm-8">@Model.FirstName</dd>
                <dt class="col-sm-4">Last Name</dt>
                <dd class="col-sm-8">@Model.LastName</dd>
            </dl>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-3">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger">Yes, Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
